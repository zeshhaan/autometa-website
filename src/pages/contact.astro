---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Autometa. Schedule a consultation, send us a message, or chat with us on WhatsApp. We're here to help with your software and automation needs."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 lg:py-28">
    <!-- Background Effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 mb-6">
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          <span class="text-sm text-blue-300">We typically respond within 24 hours</span>
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Let's Build Something
          <span class="gradient-text block mt-2">Great Together</span>
        </h1>

        <p class="text-lg md:text-xl text-slate-400">
          Ready to transform your business with custom software and automation? Reach out and let's discuss how we can help.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-8 mb-16">
        <!-- Email -->
        <a href="mailto:hello@autometa.dev" class="gradient-border p-6 hover:scale-105 transition-transform">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-white">Email Us</h3>
              <p class="text-blue-400">hello@autometa.dev</p>
            </div>
          </div>
        </a>

        <!-- WhatsApp -->
        <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" class="gradient-border p-6 hover:scale-105 transition-transform">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-white">WhatsApp</h3>
              <p class="text-emerald-400">Chat with us</p>
            </div>
          </div>
        </a>

        <!-- Schedule -->
        <a href="#book" class="gradient-border p-6 hover:scale-105 transition-transform">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-cyan-500/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-white">Book a Call</h3>
              <p class="text-cyan-400">Schedule consultation</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Main Content Grid -->
      <div class="grid lg:grid-cols-5 gap-12">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="gradient-border p-8">
            <h2 class="text-2xl font-bold text-white mb-2">Send Us a Message</h2>
            <p class="text-slate-400 mb-8">Fill out the form below and we'll get back to you within 24 hours.</p>
            <ContactForm />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Calendly Booking -->
          <div id="book">
            <CalendlyEmbed />
          </div>

          <!-- FAQ -->
          <div class="gradient-border p-6">
            <h3 class="text-lg font-semibold text-white mb-4">Common Questions</h3>
            <div class="space-y-4">
              <div>
                <h4 class="text-slate-300 font-medium mb-1">What's your typical response time?</h4>
                <p class="text-slate-500 text-sm">We aim to respond to all inquiries within 24 hours during business days.</p>
              </div>
              <div>
                <h4 class="text-slate-300 font-medium mb-1">Do you offer free consultations?</h4>
                <p class="text-slate-500 text-sm">Yes! Our initial consultation is completely free. We'll discuss your needs and provide recommendations.</p>
              </div>
              <div>
                <h4 class="text-slate-300 font-medium mb-1">What information should I include?</h4>
                <p class="text-slate-500 text-sm">Tell us about your business, current challenges, and what you're hoping to achieve. The more detail, the better!</p>
              </div>
            </div>
          </div>

          <!-- Trust Signals -->
          <div class="gradient-border p-6">
            <h3 class="text-lg font-semibold text-white mb-4">Why Work With Us</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-300 text-sm">No hidden fees or surprises</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-300 text-sm">One-time pricing, no subscriptions</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-300 text-sm">Dedicated support team</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-300 text-sm">100% satisfaction guarantee</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
