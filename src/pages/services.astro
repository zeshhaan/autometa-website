---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Testimonial from '../components/Testimonial.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    icon: 'code',
    title: 'Website Development',
    description: 'Modern, fast, and conversion-optimized websites built with the latest technologies.',
    features: [
      'New website builds from scratch',
      'Website redesigns and modernization',
      'Bug fixes and performance optimization',
      'Mobile-responsive design',
      'Fast loading speeds (Core Web Vitals)',
    ],
  },
  {
    icon: 'search',
    title: 'SEO Services',
    description: 'Proven strategies that drive organic traffic and quality leads to your business.',
    features: [
      'Technical SEO audits and fixes',
      'On-page optimization',
      'Content strategy and creation',
      'Local SEO for businesses',
      'Monthly reporting and analytics',
    ],
  },
  {
    icon: 'cart',
    title: 'E-commerce SEO',
    description: 'Specialized SEO for online stores to increase visibility and sales.',
    features: [
      'Product page optimization',
      'Category structure optimization',
      'Schema markup for products',
      'Competitor analysis',
      'Conversion rate optimization',
    ],
  },
  {
    icon: 'document',
    title: 'CMS Integration',
    description: 'Content management systems that empower your team to update your website easily.',
    features: [
      'Headless CMS setup (Sanity, Strapi)',
      'WordPress customization',
      'Custom admin panels',
      'Content workflow design',
      'Team training and documentation',
    ],
  },
  {
    icon: 'chat',
    title: 'AI Chatbot Integration',
    description: 'Intelligent chat agents that handle customer inquiries 24/7.',
    features: [
      'Custom AI chatbot development',
      'Integration with existing systems',
      'Training on your business data',
      'Multi-language support',
      'Analytics and conversation insights',
    ],
  },
  {
    icon: 'sparkles',
    title: 'Custom Software Solutions',
    description: 'Tailored software built specifically for your business needs.',
    features: [
      'Business process automation',
      'Custom dashboards and reporting',
      'API integrations',
      'Legacy system modernization',
      'Ongoing maintenance and support',
    ],
  },
];

const process = [
  {
    step: '01',
    title: 'Discovery',
    description: 'We learn about your business, goals, and challenges. This helps us understand exactly what you need.',
  },
  {
    step: '02',
    title: 'Strategy',
    description: 'We develop a clear plan of action, including timeline, deliverables, and success metrics.',
  },
  {
    step: '03',
    title: 'Execution',
    description: 'Our team gets to work, keeping you updated throughout the process with regular check-ins.',
  },
  {
    step: '04',
    title: 'Launch & Support',
    description: 'We launch your project and provide ongoing support to ensure continued success.',
  },
];

const testimonials = [
  {
    quote: 'Within a month of their SEO work, we started seeing quality leads come in. Best investment we\'ve made for our business.',
    author: 'Michael R.',
    role: 'CEO',
    company: 'TechServe Solutions',
  },
  {
    quote: 'They redesigned our outdated website and the difference is night and day. Load times went from 8 seconds to under 2.',
    author: 'Jennifer L.',
    role: 'Marketing Director',
    company: 'Coastal Properties',
  },
];
---

<Layout
  title="Services"
  description="Web development, SEO, CMS integration, and AI chatbot services. We help businesses establish and grow their digital presence with custom solutions."
>
  <!-- Hero Section -->
  <Hero
    badge="Our Services"
    title="Digital Solutions That"
    highlight="Drive Results"
    subtitle="From website development to SEO and AI integrations, we provide end-to-end digital services that help your business grow."
    primaryCta={{ text: 'Get in Touch', href: '/contact' }}
    secondaryCta={{ text: 'View Our Work', href: '#services' }}
  />

  <!-- Services Grid -->
  <section id="services" class="py-20 lg:py-28 bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="gradient-border p-8">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center mb-6">
              {service.icon === 'code' && (
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              )}
              {service.icon === 'search' && (
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              )}
              {service.icon === 'cart' && (
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              )}
              {service.icon === 'document' && (
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
              {service.icon === 'chat' && (
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              )}
              {service.icon === 'sparkles' && (
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              )}
            </div>

            <h3 class="text-xl font-bold text-white mb-3">{service.title}</h3>
            <p class="text-slate-400 mb-6">{service.description}</p>

            <ul class="space-y-2">
              {service.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-slate-300">
                  <svg class="w-4 h-4 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-blue-400 font-medium mb-4 block">Our Process</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          How We Work With You
        </h2>
        <p class="text-lg text-slate-400">
          A straightforward process designed to deliver results efficiently.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map((step, index) => (
          <div class="relative">
            <div class="gradient-border p-6 h-full">
              <div class="text-5xl font-bold text-blue-500/20 mb-4">{step.step}</div>
              <h3 class="text-lg font-semibold text-white mb-2">{step.title}</h3>
              <p class="text-slate-400 text-sm">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Success Stories -->
  <section class="py-20 lg:py-28 bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-blue-400 font-medium mb-4 block">Success Stories</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Results That Speak for Themselves
        </h2>
        <p class="text-lg text-slate-400">
          Our clients see real improvements in their digital presence and business results.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {testimonials.map((testimonial) => (
          <Testimonial
            quote={testimonial.quote}
            author={testimonial.author}
            role={testimonial.role}
            company={testimonial.company}
          />
        ))}
      </div>

      <!-- Results Stats -->
      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl font-bold gradient-text mb-2">30 days</div>
          <div class="text-slate-400">Average time to first leads</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold gradient-text mb-2">2x</div>
          <div class="text-slate-400">Average traffic increase</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold gradient-text mb-2">4x</div>
          <div class="text-slate-400">Faster page load times</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold gradient-text mb-2">100%</div>
          <div class="text-slate-400">Client satisfaction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA
    title="Ready to Grow Your Digital Presence?"
    subtitle="Let's discuss how our services can help you achieve your business goals."
    primaryCta={{ text: 'Get a Free Consultation', href: '/contact' }}
    secondaryCta={{ text: 'View Solutions', href: '/use-cases/e-commerce' }}
  />
</Layout>
