---
import Section from './Section.astro';

// Real technology logos in their original colours (self-hosted in public/logos/tech).
const techs = [
  { file: 'elixir.svg', name: 'Elixir', desc: 'Concurrent, fault-tolerant backends on the BEAM.' },
  { file: 'typescript.svg', name: 'TypeScript', desc: 'Type-safe code from the database to the browser.' },
  { file: 'python.svg', name: 'Python', desc: 'AI, automation and data pipelines where it fits best.' },
  { file: 'cloudflare.svg', name: 'Cloudflare', desc: 'Global edge hosting, fast everywhere by default.' },
  { file: 'postgresql.svg', name: 'Postgres', desc: 'The rock-solid relational core under every product.' },
  { file: 'bun.svg', name: 'Bun', desc: 'All-in-one, blazing-fast JavaScript runtime & tooling.' },
  { file: 'tanstack.png', name: 'TanStack', desc: 'Type-safe routing, data and tables on the frontend.' },
  { file: 'tailwindcss.svg', name: 'Tailwind CSS', desc: 'Utility-first styling for fast, consistent UI.' },
];
---

<Section
  id="stack"
  eyebrow="Our stack"
  title="Built on a fast, modern foundation"
  description="We pick proven, type-safe tools that keep your software quick, reliable and cheap to run for years."
>
  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {techs.map((t, i) => (
      <div
        class="reveal group flex flex-col gap-3 rounded-xl border border-border bg-card p-6 transition-[transform,border-color] duration-200 ease-out hover:-translate-y-0.5 hover:border-border-strong card-highlight"
        style={`--reveal-delay: ${(i % 4) * 60}ms`}
      >
        <span class="flex size-11 items-center justify-center rounded-lg border border-border bg-card-muted">
          <img
            src={`/logos/tech/${t.file}`}
            alt={`${t.name} logo`}
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
            class="size-6 object-contain"
          />
        </span>
        <h3 class="text-base font-medium tracking-tight text-foreground">{t.name}</h3>
        <p class="text-sm leading-relaxed text-muted-foreground">{t.desc}</p>
      </div>
    ))}
  </div>
</Section>
