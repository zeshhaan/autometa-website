---
interface Props {
  quote: string;
  author: string;
  role: string;
  company: string;
  avatar?: string;
}

const { quote, author, role, company, avatar } = Astro.props;
---

<div class="gradient-border p-8">
  <svg class="w-10 h-10 text-blue-400/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
  </svg>

  <p class="text-lg text-slate-300 mb-6 leading-relaxed">"{quote}"</p>

  <div class="flex items-center gap-4">
    {avatar ? (
      <img src={avatar} alt={author} class="w-12 h-12 rounded-full object-cover" />
    ) : (
      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center">
        <span class="text-white font-semibold text-lg">{author.charAt(0)}</span>
      </div>
    )}
    <div>
      <div class="font-semibold text-white">{author}</div>
      <div class="text-sm text-slate-400">{role}, {company}</div>
    </div>
  </div>
</div>
