---
import Icon from './Icon.astro';
import { site } from '../data/site';

const waNumber = site.whatsapp.replace(/[^0-9]/g, '');
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent("Hi Autometa, I'd like to talk about software for my business.")}`;
const telHref = `tel:${site.whatsapp.replace(/[^0-9+]/g, '')}`;
---

<!-- Floating trigger -->
<button
  id="contact-fab"
  type="button"
  aria-label="Contact us"
  aria-haspopup="dialog"
  class="group fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full border border-border bg-card/90 py-2.5 pl-2.5 pr-3 text-sm font-medium shadow-lg backdrop-blur-md transition-transform duration-150 ease-out hover:-translate-y-0.5 active:scale-[0.96] card-highlight"
>
  <span class="inline-flex size-7 items-center justify-center rounded-full bg-[#25D366] text-white">
    <Icon name="whatsapp" size={17} />
  </span>
  <span class="hidden sm:inline">Chat with us</span>
</button>

<!-- Contact modal -->
<div
  id="contact-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
>
  <div class="modal-backdrop absolute inset-0 bg-overlay backdrop-blur-sm"></div>

  <div class="modal-panel relative w-full max-w-sm overflow-hidden rounded-2xl border border-border bg-card shadow-xl card-highlight">
    <!-- Close -->
    <button
      id="contact-modal-close"
      type="button"
      aria-label="Close"
      class="absolute right-3 top-3 z-10 inline-flex size-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-card-muted hover:text-foreground"
    >
      <Icon name="x" size={18} />
    </button>

    <!-- Header -->
    <div class="flex flex-col items-center gap-3 px-6 pb-5 pt-8 text-center">
      <span class="inline-flex size-12 items-center justify-center rounded-xl bg-[#25D366]/15 text-[#25D366]">
        <Icon name="chat" size={24} />
      </span>
      <div>
        <h2 id="contact-modal-title" class="text-balance text-lg font-medium tracking-tight text-foreground">
          Let's see how your business runs
        </h2>
        <p class="mt-1.5 text-pretty text-sm leading-relaxed text-muted-foreground">
          Call or WhatsApp anytime. We can also visit your shop or business, see how you work, and show you what to build.
        </p>
      </div>
    </div>

    <!-- Availability -->
    <div class="flex items-center justify-center gap-2 border-y border-border bg-card-muted/40 px-6 py-2.5 text-xs text-muted-foreground">
      <span class="relative flex size-1.5">
        <span class="absolute inline-flex size-full animate-ping rounded-full bg-success opacity-75"></span>
        <span class="relative inline-flex size-1.5 rounded-full bg-success"></span>
      </span>
      Call or message anytime
    </div>

    <!-- Actions -->
    <div class="flex flex-col gap-3 p-5">
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-lg bg-[#25D366] p-3.5 text-white transition-transform duration-150 ease-out hover:-translate-y-0.5 active:scale-[0.98]"
      >
        <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-lg bg-white/20">
          <Icon name="whatsapp" size={20} />
        </span>
        <span class="flex-1 text-left">
          <span class="block text-sm font-semibold">Message on WhatsApp</span>
          <span class="block text-xs text-white/80">Chat or arrange a visit, anytime</span>
        </span>
        <Icon name="arrow-right" size={18} class="transition-transform duration-200 group-hover:translate-x-0.5" />
      </a>

      <a
        href={telHref}
        class="group flex items-center gap-3 rounded-lg border border-border bg-card-muted p-3.5 text-foreground transition-[transform,border-color] duration-150 ease-out hover:-translate-y-0.5 hover:border-border-strong active:scale-[0.98] card-highlight"
      >
        <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-lg border border-border bg-card text-accent">
          <Icon name="phone" size={18} />
        </span>
        <span class="flex-1 text-left">
          <span class="block text-sm font-semibold">Call us</span>
          <span class="block text-xs text-muted-foreground">Talk to us directly, anytime</span>
        </span>
        <Icon name="arrow-right" size={18} class="text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5" />
      </a>
    </div>

    <!-- Footer -->
    <div class="px-6 pb-6">
      <p class="text-center text-xs text-muted-foreground">
        You reach the team that builds the software, not a call centre.
      </p>
    </div>
  </div>
</div>

<style>
  #contact-modal { display: none; }
  #contact-modal.is-open { display: flex; }

  #contact-modal .modal-backdrop {
    opacity: 0;
    transition: opacity 0.2s var(--ease-smooth);
  }
  #contact-modal.is-open .modal-backdrop { opacity: 1; }

  #contact-modal .modal-panel {
    opacity: 0;
    scale: 0.96;
    transform-origin: bottom right;
    transition: opacity 0.22s var(--ease-smooth), scale 0.22s var(--ease-smooth);
    will-change: transform, opacity;
  }
  #contact-modal.is-open .modal-panel { opacity: 1; scale: 1; }
</style>

<script>
  const fab = document.getElementById('contact-fab');
  const modal = document.getElementById('contact-modal');
  const closeBtn = document.getElementById('contact-modal-close');
  const backdrop = modal?.querySelector('.modal-backdrop');
  let lastFocused: HTMLElement | null = null;

  const openModal = () => {
    if (!modal) return;
    lastFocused = document.activeElement as HTMLElement;
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => closeBtn?.focus());
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    lastFocused?.focus();
  };

  fab?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeModal();
  });

  // Any element with [data-contact-modal] opens the same modal.
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('[data-contact-modal]');
    if (trigger) {
      e.preventDefault();
      openModal();
    }
  });
</script>
