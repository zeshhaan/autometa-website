---
import Icon from './Icon.astro';

interface Props {
  icon?: string;
  class?: string;
}
const { icon, class: className = '' } = Astro.props;
---

<span
  class={`inline-flex w-fit items-center gap-1.5 rounded-full border border-border bg-badge/5 px-3 py-1 text-xs font-medium backdrop-blur-sm dark:bg-badge ${className}`}
>
  {icon && <Icon name={icon} size={13} class="text-accent" />}
  <span class="shiny-text">
    <slot />
  </span>
</span>
