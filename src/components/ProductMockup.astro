---
interface Props {
  images: {
    src: string;
    alt: string;
    caption?: string;
  }[];
  layout?: 'single' | 'double' | 'triple';
}

const { images, layout = 'single' } = Astro.props;
---

<div class="product-mockup">
  {layout === 'single' && images[0] && (
    <div class="relative max-w-5xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-blue-500/10 border border-slate-700/50">
        <img
          src={images[0].src}
          alt={images[0].alt}
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
      {images[0].caption && (
        <p class="text-center text-slate-400 text-sm mt-4">{images[0].caption}</p>
      )}
    </div>
  )}

  {layout === 'double' && (
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      {images.slice(0, 2).map((image) => (
        <div class="relative">
          <div class="relative rounded-xl overflow-hidden shadow-xl shadow-blue-500/10 border border-slate-700/50">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
          {image.caption && (
            <p class="text-center text-slate-400 text-sm mt-3">{image.caption}</p>
          )}
        </div>
      ))}
    </div>
  )}

  {layout === 'triple' && (
    <div class="space-y-8">
      {/* Main large image */}
      {images[0] && (
        <div class="relative max-w-4xl mx-auto">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-blue-500/10 border border-slate-700/50">
            <img
              src={images[0].src}
              alt={images[0].alt}
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
          {images[0].caption && (
            <p class="text-center text-slate-400 text-sm mt-4">{images[0].caption}</p>
          )}
        </div>
      )}

      {/* Two smaller images */}
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
        {images.slice(1, 3).map((image) => (
          <div class="relative">
            <div class="relative rounded-xl overflow-hidden shadow-xl shadow-blue-500/10 border border-slate-700/50">
              <img
                src={image.src}
                alt={image.alt}
                class="w-full h-auto"
                loading="lazy"
              />
            </div>
            {image.caption && (
              <p class="text-center text-slate-400 text-sm mt-3">{image.caption}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .product-mockup img {
    transition: transform 0.3s ease;
  }

  .product-mockup div:hover img {
    transform: scale(1.02);
  }
</style>
