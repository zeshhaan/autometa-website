---
import Icon from './Icon.astro';
import type { Product } from '../data/site';

interface Props {
  product: Product;
  index?: number;
}
const { product, index = 0 } = Astro.props;
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-xl border border-border bg-card p-6 transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-border-strong hover:shadow-xl card-highlight md:p-8"
  style={`--reveal-delay: ${index * 80}ms`}
>
  <!-- accent wash, tinted per product hue -->
  <div
    class="pointer-events-none absolute -right-16 -top-16 size-48 rounded-full opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100"
    style={`background: oklch(0.7 0.16 ${product.accentHue}); opacity:0;`}
  ></div>

  <div class="relative flex items-center justify-between gap-3">
    <span
      class="inline-flex size-11 items-center justify-center rounded-lg border border-border bg-card-muted text-foreground"
      style={`color: oklch(0.72 0.15 ${product.accentHue})`}
    >
      <Icon name={product.icon} size={22} />
    </span>
    <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card-muted px-2.5 py-1 text-xs text-muted-foreground">
      {product.liveUrl && <span class="size-1.5 rounded-full bg-success"></span>}
      {product.badge}
    </span>
  </div>

  <div class="relative mt-5 flex flex-1 flex-col">
    <p class="font-mono text-xs uppercase tracking-[0.16em] text-muted-foreground">{product.category}</p>
    <h3 class="mt-2 text-xl font-medium tracking-tight text-foreground">{product.name}</h3>
    <p class="mt-1 text-[15px] font-medium text-foreground/90">{product.tagline}</p>
    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{product.summary}</p>

    <ul class="mt-5 grid gap-2">
      {product.highlights.slice(0, 4).map((h) => (
        <li class="flex items-start gap-2 text-sm text-foreground/80">
          <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
          <span>{h}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="relative mt-6 flex items-center justify-between border-t border-border pt-5">
    <a
      href={`/solutions/${product.slug}`}
      class="inline-flex items-center gap-1.5 text-sm font-medium text-foreground transition-colors hover:text-accent"
    >
      Explore {product.name}
      <Icon name="arrow-right" size={16} class="transition-transform duration-200 group-hover:translate-x-0.5" />
    </a>
    {product.liveUrl && (
      <a
        href={product.liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground"
      >
        {product.liveLabel}
        <Icon name="arrow-up-right" size={13} />
      </a>
    )}
  </div>
</article>
