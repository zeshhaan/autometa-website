---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  index?: number;
  accentHue?: number;
}
const { icon, title, description, index = 0, accentHue } = Astro.props;
const iconColor = accentHue ? `color: oklch(0.72 0.15 ${accentHue})` : '';
---

<div
  class="reveal group relative flex flex-col gap-3 rounded-xl border border-border bg-card p-6 transition-[transform,border-color] duration-300 hover:-translate-y-0.5 hover:border-border-strong card-highlight"
  style={`--reveal-delay: ${(index % 3) * 70}ms`}
>
  <span
    class="inline-flex size-10 items-center justify-center rounded-lg border border-border bg-card-muted text-foreground transition-colors group-hover:bg-accent-soft"
    style={iconColor}
  >
    <Icon name={icon} size={20} />
  </span>
  <h3 class="text-base font-medium tracking-tight text-foreground">{title}</h3>
  <p class="text-sm leading-relaxed text-muted-foreground">{description}</p>
</div>
