const iconPath = icons[icon] || icons.check;
---

<div class="gradient-border p-6 hover:scale-105 transition-transform duration-300">
  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-cyan-500/20 flex items-center justify-center mb-4">
    <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconPath} />
  </div>
  <h3 class="text-lg font-semibold text-white mb-2">{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed">{description}</p>
</div>
