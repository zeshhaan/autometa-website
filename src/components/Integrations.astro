---
import Section from './Section.astro';

// Real brand logos in their original colours (self-hosted in public/logos).
const integrations: { name: string; file: string }[] = [
  { name: 'WhatsApp', file: 'whatsapp.svg' },
  { name: 'Google', file: 'google.svg' },
  { name: 'Gemini', file: 'gemini.svg' },
  { name: 'Zoho', file: 'zoho.svg' },
  { name: 'Stripe', file: 'stripe.svg' },
  { name: 'Meta', file: 'meta.svg' },
  { name: 'Tamara', file: 'tamara.png' },
  { name: 'Freepik', file: 'freepik.svg' },
];
---

<Section
  id="integrations"
  eyebrow="Integrations"
  title="Plays nicely with your stack"
  description="Connect the tools you already run — payments, messaging, AI and the rest. Not on the list? We'll build the integration."
>
  <div class="mt-14 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
    {integrations.map((it, i) => (
      <div
        class="reveal group flex flex-col items-center gap-3 rounded-xl border border-border bg-card p-3 transition-[translate,border-color] duration-200 ease-out hover:-translate-y-0.5 hover:border-border-strong card-highlight"
        style={`--reveal-delay: ${(i % 4) * 60}ms`}
      >
        <div class="flex h-16 w-full items-center justify-center rounded-sm bg-white px-5 shadow-[0_1px_2px_-1px_rgba(0,0,0,0.08),0_2px_5px_-3px_rgba(0,0,0,0.05)] ring-1 ring-black/[0.04]">
          <img
            src={`/logos/integrations/${it.file}`}
            alt={`${it.name} logo`}
            loading="lazy"
            decoding="async"
            class="max-h-9 w-auto max-w-[82%] object-contain"
          />
        </div>
        <span class="pb-1 text-sm font-medium text-foreground/85">{it.name}</span>
      </div>
    ))}
  </div>

  <p class="reveal mt-6 text-pretty text-center text-sm text-muted-foreground">
    …and many more. If your business runs on it, we can connect it.
  </p>
</Section>
